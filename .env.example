# Application
APP_ENV=development
APP_NAME=BoardTrace
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=boardtrace
POSTGRES_USER=boardtrace
POSTGRES_PASSWORD=change-me-locally
DATABASE_URL=postgresql+psycopg://boardtrace:change-me-locally@localhost:5432/boardtrace

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Stockfish
STOCKFISH_PATH=/usr/local/bin/stockfish
STOCKFISH_THREADS=2

# Object storage
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=boardtrace-local
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY=change-me-locally
OBJECT_STORAGE_SECRET_KEY=change-me-locally

# Capture retention
CAPTURE_RETENTION_HOURS=24
STORE_FULL_SCREEN_CAPTURES=false

# Analysis locking
ANALYSIS_LOCK_ENABLED=true
GAME_FINISH_CONFIRMATION_SECONDS=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
