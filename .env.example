# Application
APP_ENV=development
APP_NAME=BoardTrace
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=boardtrace
POSTGRES_USER=boardtrace
POSTGRES_PASSWORD=change-me-locally
BOARDTRACE_DATABASE_URL=postgresql+asyncpg://boardtrace:boardtrace@localhost:5432/boardtrace
BOARDTRACE_DATABASE_ECHO=false
BOARDTRACE_DATABASE_POOL_SIZE=5
BOARDTRACE_DATABASE_MAX_OVERFLOW=10
BOARDTRACE_DATABASE_POOL_TIMEOUT=30
BOARDTRACE_DATABASE_POOL_RECYCLE=1800

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
BOARDTRACE_REDIS_URL=redis://localhost:6379/0
BOARDTRACE_ANALYSIS_QUEUE_NAME=boardtrace.analysis.jobs
BOARDTRACE_ANALYSIS_LEASE_SECONDS=120
BOARDTRACE_ANALYSIS_HEARTBEAT_SECONDS=30

# Stockfish (used only by the backend worker; never expose this path to clients)
BOARDTRACE_STOCKFISH_PATH=/usr/local/bin/stockfish
BOARDTRACE_STOCKFISH_TIMEOUT_SECONDS=30
BOARDTRACE_STOCKFISH_THREADS=2
BOARDTRACE_STOCKFISH_HASH_MB=64
BOARDTRACE_ANALYSIS_DEPTH=12
BOARDTRACE_ANALYSIS_MAX_POSITION_TIME_MS=500
BOARDTRACE_ANALYSIS_MAX_GAME_TIME_MS=60000
BOARDTRACE_ANALYSIS_MAX_MOVES=300
BOARDTRACE_ANALYSIS_MAX_POSITIONS=301

# Object storage
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=boardtrace-local
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY=change-me-locally
OBJECT_STORAGE_SECRET_KEY=change-me-locally

# Capture retention
CAPTURE_RETENTION_HOURS=24
STORE_FULL_SCREEN_CAPTURES=false

# Analysis locking
ANALYSIS_LOCK_ENABLED=true
GAME_FINISH_CONFIRMATION_SECONDS=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
